# ── Theme data source ────────────────────────────────────────────────────────
# Nova runs OFFLINE with mock data by default (lib/collections.json) — no store,
# no backend needed. Copy this to `.env` ONLY to preview against a REAL store.
#
#   cp .env.example .env
#
# Vite exposes VITE_* to the app. main.tsx (CSR) and entry-server.tsx (SSG) both
# switch to live data when BACKEND + STORE_ID are set, else fall back to mock.

# The store's cell Storefront API base (which cell the store lives on).
VITE_TANQORY_BACKEND=https://api-do-sgp1.tanqory.com

# The store UUID to preview (the :storeId path param).
VITE_TANQORY_STORE_ID=00000000-0000-0000-0000-000000000000

# Publishable storefront token — x-publishable-key. PUBLISHABLE = safe to share,
# NOT a secret. Optional (the Storefront API is readable without it).
VITE_TANQORY_STOREFRONT_TOKEN=
