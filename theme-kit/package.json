{
  "name": "@tanqory/theme-kit",
  "version": "0.1.0",
  "type": "module",
  "description": "Framework for Tanqory React themes \u2014 block registry, JSON-tree renderer, data layer, mount(). Themes depend on this and only author blocks/ + pages/.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tanqory/tanqory-platform-studio-new.git",
    "directory": "packages/theme-kit"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org",
    "access": "public"
  },
  "files": [
    "dist"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/types/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "default": "./dist/index.js"
    },
    "./ssg": {
      "types": "./dist/types/ssg.d.ts",
      "default": "./dist/ssg.js"
    }
  },
  "peerDependencies": {
    "react": "^18 || ^19",
    "react-dom": "^18 || ^19"
  }
}